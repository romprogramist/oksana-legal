DATABASE_URL="postgresql://postgres:password@localhost:5432/oksana_legal_db"

# Admin panel (generate your own; these are placeholders)
ADMIN_LOGIN="admin_change_me"
ADMIN_PASSWORD="change_me_to_something_long_and_random"
ADMIN_SESSION_SECRET="change_me_to_64_hex_chars"

# Tochka Bank — internet acquiring
# JWT-токен с правами MakeAcquiringOperation/ReadAcquiringData (в ЛК Точки → "Интеграция API")
# customerCode зашит в коде src/lib/tochka.ts (305042189) — взят из claim "customer_code" этого JWT.
TOCHKA_JWT_TOKEN=""
TOCHKA_API_URL="https://enter.tochka.com/uapi/acquiring/v1.0"
TOCHKA_PUBLIC_KEY_URL="https://enter.tochka.com/doc/openapi/static/keys/public"
